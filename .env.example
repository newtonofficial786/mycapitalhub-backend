# Environment (local, development, production)
APP_ENV=local

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=gaming_platform
DB_USERNAME=root
DB_PASSWORD=

# Application Configuration
APP_URL=http://localhost:8000
API_URL=http://localhost:8000/api

# JWT Configuration
JWT_SECRET=change-this-secret-key-in-production
JWT_EXPIRY=86400

# ===== Payment Gateway: GalePay =====
GALEPAY_MERCHANT_ID=your_merchant_id
GALEPAY_MERCHANT_KEY=your_merchant_key
GALEPAY_API_BASE=https://gateway.openzpay.cc
# Callback URL is auto-built from APP_URL: {APP_URL}/api/payment/galepay/callback
# 300=India test, 301=India production, 302=India native (contact ops)
GALEPAY_CHANNEL_CODE=300