# Environment (local, development, production)
APP_ENV=production

# Database Configuration
# Local:  DB_HOST=localhost
# Prod:   DB_HOST=sdb-77.hosting.stackcp.net
DB_HOST=sdb-77.hosting.stackcp.net
DB_PORT=3306
DB_DATABASE=tatainvest-35303735512d
DB_USERNAME=admin-5bc5
DB_PASSWORD=your_password_here

# Application Configuration
# Local:  APP_URL=http://localhost:8000
# Prod:   APP_URL=https://tatainvest.in/tatainvest
APP_URL=https://tatainvest.in/tatainvest
FRONTEND_URL=https://mycapitalhub.xyz
API_URL=https://tatainvest.in/tatainvest/api

# JWT Configuration
JWT_SECRET=change-this-secret-key-in-production
JWT_EXPIRY=86400

# ===== Payment Gateway: WatchPays =====
# callback_url in API request = frontend redirect URL (auto-built from FRONTEND_URL)
# Server-to-server webhook = configure in WatchPays merchant dashboard
WATCHPAYS_MERCHANT_ID=your_merchant_id
WATCHPAYS_API_KEY=your_api_key

# ===== Payment Gateway: GalePay =====
GALEPAY_MERCHANT_ID=your_merchant_id
GALEPAY_MERCHANT_KEY=your_merchant_key
GALEPAY_API_BASE=https://gateway.openzpay.cc
# callback_url = server-to-server webhook (auto-built from APP_URL)
# returnUrl = frontend redirect (auto-built from FRONTEND_URL)
# 300=India test, 301=India production, 302=India native (contact ops)
GALEPAY_CHANNEL_CODE=301

# ===== Payment Gateway: Jazpay =====
JAZPAY_MERCHANT_ID=your_merchant_id
JAZPAY_API_KEY=your_api_key
# callback_url = server-to-server webhook (auto-built from APP_URL)
# return_url = frontend redirect (auto-built from FRONTEND_URL)

# ===== Payment Gateway: Zoxpay =====
ZOXPAY_MERCHANT_ID=your_merchant_id
ZOXPAY_API_KEY=your_api_key
# callback_url = server-to-server webhook (auto-built from APP_URL)
# return_url = frontend redirect (auto-built from FRONTEND_URL)
