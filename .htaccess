<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /backend/

    # Block access to sensitive files
    <FilesMatch "^\.env">
        Order allow,deny
        Deny from all
    </FilesMatch>
    <FilesMatch "\.log$">
        Order allow,deny
        Deny from all
    </FilesMatch>
    <FilesMatch "\.(sql|bak|old|orig)$">
        Order allow,deny
        Deny from all
    </FilesMatch>

    # Security headers
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # CORS headers (will be overridden by PHP for specific origins)
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
    Header always set Access-Control-Max-Age "86400"

    # Handle OPTIONS preflight at Apache level (return 204 No Content)
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^ - [R=204,L]

    # If the file or folder doesn't exist, send to index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

<IfModule !mod_rewrite.c>
    <FilesMatch "^\.env">
        Order allow,deny
        Deny from all
    </FilesMatch>
    # Fallback if mod_rewrite is not available
    <IfModule mod_headers.c>
        Header set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Header set Access-Control-Allow-Headers "Content-Type, Authorization"
        Header set X-Frame-Options "DENY"
        Header set X-Content-Type-Options "nosniff"
    </IfModule>
</IfModule>
